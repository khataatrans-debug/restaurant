{
  "hosting": {
    "site": "tienphatvt",
    "public": ".",
    "cleanUrls": false,
    "headers": [{
      "source": "**/*.html",
      "headers": [{"key": "Cache-Control", "value": "no-cache"}]
    }],
    "rewrites": [
      {"source": "/", "destination": "/landing.html"}
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}